class Memory:
    def __init__(self):
        self.stack = []
        self.heap = {}
        self.next_id = 0

    def alloc(self, value):
        addr = self.next_id
        self.heap[addr] = value
        self.next_id += 1
        return addr

    def get(self, addr):
        return self.heap.get(addr, None)

    def free(self, addr):
        if addr in self.heap:
            del self.heap[addr]
""",

