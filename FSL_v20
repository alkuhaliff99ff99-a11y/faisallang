from memory import Memory
from gc import GC

class VM:
    def __init__(self, instructions=None, constants=None):
        self.instructions = instructions or []
        self.constants = constants or []
        self.ip = 0

        self.memory = Memory()
        self.gc = GC(self.memory)
        self.debug = False

    def run(self):
        while self.ip < len(self.instructions):
            op, arg = self.instructions[self.ip]
            self.ip += 1

            if self.debug:
                print(f"[FSL VM] {op} {arg}")

            if op == "LOAD_CONST":
                self.memory.stack.append(self.constants[arg])

            elif op == "PRINT":
                print(self.memory.stack.pop())

            elif op == "STORE":
                self.memory.heap[arg] = self.memory.stack.pop()

            elif op == "LOAD":
                self.memory.stack.append(self.memory.get(arg))

            elif op == "GC":
                self.gc.collect()
""",

